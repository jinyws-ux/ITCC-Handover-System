{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2020"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "src"
  ],
  "references": [],
  "exclude": [
    "src/AppV2.tsx",
    "src/AppV3.tsx",
    "src/AppV4.tsx",
    "src/AppV5.tsx",
    "src/AppV6.tsx",
    "src/BilingualApp.tsx",
    "src/PrototypeApp.tsx",
    "src/StableApp.tsx"
  ]
}